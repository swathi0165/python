a = input("enter a password:")
up=0
lp=0
dg=0
sp=0
if len(a)>7:
    for i in a:
        if i.isupper():
            up=up+1
        elif i.islower():
            lp=lp+1
        elif i.isdigit():
            dg=dg+1
        else:
             sp=sp+1
        
    if up>0 and lp>0 and dg>0 and sp>0:
        
        print("strong")
    else:
        print("weak") 
else:
    print("due to weak password")
